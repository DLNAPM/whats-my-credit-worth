{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with financial data and settings",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user is a premium user"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user is an admin"
        },
        "isFrozen": {
          "type": "boolean",
          "description": "Whether the user account is frozen"
        },
        "createdAt": {
          "type": "string",
          "description": "Account creation timestamp"
        },
        "lastLogin": {
          "type": "string",
          "description": "Last login timestamp"
        }
      },
      "required": ["email"]
    },
    "SupportRequest": {
      "title": "Support Request",
      "description": "Support request or feedback submitted by a user",
      "type": "object",
      "properties": {
        "to": {
          "type": "string",
          "description": "Destination support email address"
        },
        "message": {
          "type": "object",
          "description": "Detailed email message"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user submitting the request"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of creation"
        },
        "status": {
          "type": "object",
          "description": "Status of the request"
        }
      },
      "required": ["to", "message", "userId", "createdAt"]
    },
    "SharedSnapshot": {
      "title": "Shared Snapshot",
      "description": "A financial snapshot shared publicly",
      "type": "object",
      "properties": {
        "monthYear": {
          "type": "string",
          "description": "The month and year for the snapshot"
        },
        "data": {
          "type": "object",
          "description": "The complete financial data structure for the month"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of snapshot creation"
        },
        "summary": {
          "type": "object",
          "description": "Summary containing net worth and monthly income"
        }
      },
      "required": ["monthYear", "data", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User documents mapping to their unique user ID"
    },
    "support_requests/{requestId}": {
      "schema": "SupportRequest",
      "description": "Support request messages for admin and automated email routing"
    },
    "shared_snapshots/{snapshotId}": {
      "schema": "SharedSnapshot",
      "description": "Publicly shared snapshots generated by users"
    }
  }
}
